RewriteEngine On

# ---------------------------------------------------------------
# 404 HANDLER
# ---------------------------------------------------------------
ErrorDocument 404 /404.php

# ---------------------------------------------------------------
# ROUTING
# ---------------------------------------------------------------

# Public shareable site links: /s/{slug}
RewriteRule ^s/([a-zA-Z0-9\-]+)/?$ s.php?slug=$1 [L,QSA]

# ---------------------------------------------------------------
# CLEAN URLs — strip .php extension (portal & root pages only)
# api/ is intentionally excluded: fetch() calls go directly to
# /api/find-leads.php etc. and must NOT be 301'd to /api/find-leads
# ---------------------------------------------------------------

# 1. If someone requests /page.php directly (but NOT under api/),
#    redirect to /page (301)
RewriteCond %{THE_REQUEST} \s/([^.]+)\.php[\s?] [NC]
RewriteCond %{REQUEST_URI} !^/api/ [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. Portal pages: /portal/page  ->  portal/page.php (internal rewrite)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^portal/([a-zA-Z0-9_\-]+)/?$ portal/$1.php [L,QSA]

# 3. Root pages: /page  ->  page.php (internal rewrite)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_\-]+)/?$ $1.php [L,QSA]

# ---------------------------------------------------------------
# BLOCK SENSITIVE PATHS
# ---------------------------------------------------------------

# Block direct access to storage, db schemas, migrations
RewriteRule ^storage/         - [F,L]
RewriteRule ^db/              - [F,L]
RewriteRule ^sql/             - [F,L]
RewriteRule ^migrations/      - [F,L]

# Block direct access to config and PHP includes
<FilesMatch "^(config|db|userdb)\.php$">
    Require all denied
</FilesMatch>
<FilesMatch "\.(sql|sh|env|log|bak|zip)$">
    Require all denied
</FilesMatch>

# Block access to the includes/ directory entirely
RewriteRule ^includes/        - [F,L]

# ---------------------------------------------------------------
# SECURITY HEADERS
# ---------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Cache-Control "no-store, no-cache, must-revalidate" env=IS_PORTAL
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://cdnjs.cloudflare.com https://js.stripe.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; img-src 'self' data: https:; frame-src 'self'; connect-src 'self' https://api.brevo.com https://api.stripe.com; object-src 'none'; base-uri 'self';"
    Header always unset X-Powered-By
</IfModule>

ServerSignature Off
